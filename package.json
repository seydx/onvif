{
  "name": "@seydx/onvif",
  "version": "0.0.1",
  "description": "",
  "keywords": [
    "onvif"
  ],
  "homepage": "https://github.com/seydx/onvif#readme",
  "bugs": {
    "url": "https://github.com/seydx/onvif/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/seydx/onvif.git"
  },
  "license": "MIT",
  "author": "seydx (https://github.com/seydx)",
  "type": "module",
  "exports": "./build/index.js",
  "typings": "./build/index.d.ts",
  "files": [
    "build"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "run-p build:*",
    "postbuild": "tsfix",
    "build:swc": "swc ./source -d ./build --strip-leading-paths",
    "build:types": "tsc --project tsconfig.build.json",
    "check": "run-p check:*",
    "check:eslint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "check:biome": "biome check ./source",
    "fix": "run-s fix:code fix:format",
    "fix:code": "run-s 'check:eslint -- --fix'",
    "fix:format": "biome format --write ./source",
    "install-updates": "npm i --save",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prepublishOnly": "run-s build",
    "preversion": "run-s check test build",
    "test": "vitest run",
    "test:integration": "vitest run integration --coverage",
    "test:unit": "vitest run unit --coverage",
    "update": "updates --update ./"
  },
  "dependencies": {
    "undici": "^7.16.0",
    "xml2js": "0.6.2"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "9.39.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "typescript-eslint": "^8.58.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "25.6.0",
    "@types/unzipper": "^0.10.11",
    "concurrently": "^9.2.1",
    "rimraf": "^6.1.3",
    "typescript": "5.9.3",
    "updates": "^17.15.3"
  },
  "packageManager": "npm@11.6.4",
  "engines": {
    "node": ">=22"
  },
  "volta": {
    "node": "22.21.1",
    "npm": "10.9.4"
  }
}